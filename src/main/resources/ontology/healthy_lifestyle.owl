        <frequencyPerWeek rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</frequencyPerWeek>
        <supportsGoal rdf:resource="#WeightLoss"/>
        <supportsGoal rdf:resource="#Maintenance"/>
    </MindfulnessHabit>
    <ActivityHabit rdf:about="#LongRun">
        <habitName>long_run</habitName>
        <rdfs:label xml:lang="bg">Дълго кардио в събота</rdfs:label>
        <frequencyPerWeek rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</frequencyPerWeek>
        <supportsGoal rdf:resource="#Endurance"/>
    </ActivityHabit>

    <!-- ========== v7: person metrics + BMI/age reasoning ========== -->
    <owl:Class rdf:about="#BmiCategory"/>
    <owl:Class rdf:about="#AgeGroup"/>
    <owl:DatatypeProperty rdf:about="#personAge">
        <rdfs:domain rdf:resource="#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#weightKg">
        <rdfs:domain rdf:resource="#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#heightCm">
        <rdfs:domain rdf:resource="#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#bmi">
        <rdfs:domain rdf:resource="#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#minRecommendedAge">
        <rdfs:domain rdf:resource="#Exercise"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#maxRecommendedAge">
        <rdfs:domain rdf:resource="#Exercise"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#maxMealCalories">
        <rdfs:domain rdf:resource="#Meal"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    <owl:ObjectProperty rdf:about="#suitableForBmiCategory">
        <rdfs:domain rdf:resource="#Meal"/>
        <rdfs:range rdf:resource="#BmiCategory"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#suitableForAgeGroup">
        <rdfs:domain rdf:resource="#Exercise"/>
        <rdfs:range rdf:resource="#AgeGroup"/>
    </owl:ObjectProperty>

    <BmiCategory rdf:about="#NormalBmi">
        <rdfs:label xml:lang="bg">Нормално тегло (BMI 18.5–24.9)</rdfs:label>
    </BmiCategory>
    <BmiCategory rdf:about="#OverweightBmi">
        <rdfs:label xml:lang="bg">Наднормено (BMI 25–29.9)</rdfs:label>
    </BmiCategory>
    <BmiCategory rdf:about="#ObeseBmi">
        <rdfs:label xml:lang="bg">Затлъстяване (BMI 30+)</rdfs:label>
    </BmiCategory>
    <AgeGroup rdf:about="#YoungAdult">
        <rdfs:label xml:lang="bg">18–39 години</rdfs:label>
    </AgeGroup>
    <AgeGroup rdf:about="#MatureAdult">
        <rdfs:label xml:lang="bg">40–54 години</rdfs:label>
    </AgeGroup>
    <AgeGroup rdf:about="#SeniorAdult">
        <rdfs:label xml:lang="bg">55+ години</rdfs:label>
    </AgeGroup>

    <Meal rdf:about="#SeniorLightLunch">
        <rdf:type rdf:resource="#LunchMeal"/>
        <rdfs:label xml:lang="bg">Лек обяд за 55+</rdfs:label>
        <hasMealType rdf:resource="#Lunch"/>
        <containsFood rdf:resource="#Cucumber"/>
        <containsFood rdf:resource="#ChickenBreast"/>
        <containsFood rdf:resource="#Spinach"/>
        <mealSuitableForGoal rdf:resource="#WeightLoss"/>
        <mealSuitableForGoal rdf:resource="#Maintenance"/>
        <suitableForBmiCategory rdf:resource="#OverweightBmi"/>
        <suitableForBmiCategory rdf:resource="#ObeseBmi"/>
        <maxMealCalories rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">450</maxMealCalories>
    </Meal>
    <Meal rdf:about="#YouthMuscleBowl">
        <rdf:type rdf:resource="#LunchMeal"/>
        <rdfs:label xml:lang="bg">Мускулна купа за млади</rdfs:label>
        <hasMealType rdf:resource="#Lunch"/>
        <containsFood rdf:resource="#LeanBeef"/>
        <containsFood rdf:resource="#BrownRice"/>
        <containsFood rdf:resource="#Broccoli"/>
        <mealSuitableForGoal rdf:resource="#MuscleGain"/>
        <maxMealCalories rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">750</maxMealCalories>
    </Meal>

    <CardioExercise rdf:about="#LowImpactWalk">
        <rdfs:label xml:lang="bg">Лека прогулка 55+</rdfs:label>
        <durationMinutes rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">45</durationMinutes>
        <intensity>low</intensity>
        <minRecommendedAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">50</minRecommendedAge>
        <suitableForAgeGroup rdf:resource="#SeniorAdult"/>
        <exerciseSuitableForGoal rdf:resource="#WeightLoss"/>
        <exerciseSuitableForGoal rdf:resource="#Maintenance"/>
    </CardioExercise>

    <!-- Demo persons (ontology seed; runtime profiles add more) -->
    <Person rdf:about="#DemoUser">
        <username>demo</username>
        <hasGoal rdf:resource="#Maintenance"/>
        <hasActivityLevel rdf:resource="#Moderate"/>
        <tracksHabit rdf:resource="#DrinkWater"/>
        <tracksHabit rdf:resource="#Sleep8Hours"/>
        <tracksHabit rdf:resource="#Walk10000Steps"/>
        <consumes rdf:resource="#LeanLunch"/>
        <consumes rdf:resource="#HighProteinBreakfast"/>
    </Person>
    <Person rdf:about="#WeightLossUser">
        <username>weightloss_demo</username>
        <hasGoal rdf:resource="#WeightLoss"/>
        <hasActivityLevel rdf:resource="#Moderate"/>
        <tracksHabit rdf:resource="#DrinkWater"/>
        <tracksHabit rdf:resource="#MindfulEating"/>
        <tracksHabit rdf:resource="#LimitSugar"/>
        <consumes rdf:resource="#TunaSaladLunch"/>
        <consumes rdf:resource="#ProteinSnack"/>
    </Person>

    <!-- Inverse links: food contained in meals (isContainedIn ↔ containsFood) -->
    <AnimalProteinFood rdf:about="#ChickenBreast">
        <isContainedIn rdf:resource="#LeanLunch"/>
    </AnimalProteinFood>
    <AnimalProteinFood rdf:about="#Tuna">
        <isContainedIn rdf:resource="#TunaSaladLunch"/>
    </AnimalProteinFood>
    <AnimalProteinFood rdf:about="#Salmon">
        <isContainedIn rdf:resource="#BalancedDinner"/>
        <isContainedIn rdf:resource="#PostWorkoutRecovery"/>
    </AnimalProteinFood>

</rdf:RDF>
