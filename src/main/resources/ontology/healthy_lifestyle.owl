    <!-- Exercises -->
    <CardioExercise rdf:about="#Running">
        <rdfs:label xml:lang="bg">Бягане</rdfs:label>
        <durationMinutes rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">30</durationMinutes>
        <intensity>moderate</intensity>
        <hasIntensityLevel rdf:resource="#ModerateIntensity"/>
        <exerciseSuitableForGoal rdf:resource="#WeightLoss"/>
        <exerciseSuitableForGoal rdf:resource="#Endurance"/>
        <complementsExercise rdf:resource="#Yoga"/>
    </CardioExercise>
    <CardioExercise rdf:about="#Cycling">
        <rdfs:label xml:lang="bg">Колоездене</rdfs:label>
