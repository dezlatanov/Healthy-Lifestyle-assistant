    <!-- Nutrients (typed hierarchy) -->
    <Macronutrient rdf:about="#Protein">
        <rdfs:label xml:lang="bg">Протеин</rdfs:label>
    </Macronutrient>
    <Macronutrient rdf:about="#Carbohydrate">
        <rdfs:label xml:lang="bg">Въглехидрат</rdfs:label>
    </Macronutrient>
    <Macronutrient rdf:about="#Fiber">
        <rdfs:label xml:lang="bg">Фибри</rdfs:label>
    </Macronutrient>
    <Micronutrient rdf:about="#Omega3">
        <rdfs:label xml:lang="bg">Омега-3</rdfs:label>
        <nutrientSourceFood rdf:resource="#Salmon"/>
        <nutrientSourceFood rdf:resource="#Tuna"/>
    </Micronutrient>
    <Mineral rdf:about="#Iron">
        <rdfs:label xml:lang="bg">Желязо</rdfs:label>
        <nutrientSourceFood rdf:resource="#Spinach"/>
    </Mineral>
    <Vitamin rdf:about="#VitaminC">
        <rdfs:label xml:lang="bg">Витамин C</rdfs:label>
        <nutrientSourceFood rdf:resource="#Apple"/>
    </Vitamin>

    <!-- Meals (typed + balanced where applicable) -->
    <Meal rdf:about="#HighProteinBreakfast">
        <rdf:type rdf:resource="#BreakfastMeal"/>
        <rdf:type rdf:resource="#BalancedMeal"/>
        <rdfs:label xml:lang="bg">Богата на протеин закуска</rdfs:label>
        <hasMealType rdf:resource="#Breakfast"/>
        <containsFood rdf:resource="#Oatmeal"/>
        <containsFood rdf:resource="#GreekYogurt"/>
        <mealSuitableForGoal rdf:resource="#MuscleGain"/>
        <mealSuitableForGoal rdf:resource="#Maintenance"/>
    </Meal>
    <Meal rdf:about="#LeanLunch">
        <rdf:type rdf:resource="#LunchMeal"/>
        <rdf:type rdf:resource="#BalancedMeal"/>
        <rdfs:label xml:lang="bg">Лек обяд</rdfs:label>
        <hasMealType rdf:resource="#Lunch"/>
        <containsFood rdf:resource="#ChickenBreast"/>
        <containsFood rdf:resource="#Broccoli"/>
        <mealSuitableForGoal rdf:resource="#WeightLoss"/>
        <mealSuitableForGoal rdf:resource="#Maintenance"/>
    </Meal>
    <Meal rdf:about="#BalancedDinner">
        <rdf:type rdf:resource="#DinnerMeal"/>
        <rdf:type rdf:resource="#BalancedMeal"/>
        <rdfs:label xml:lang="bg">Балансирана вечеря</rdfs:label>
        <hasMealType rdf:resource="#Dinner"/>
        <containsFood rdf:resource="#Salmon"/>
        <containsFood rdf:resource="#BrownRice"/>
        <mealSuitableForGoal rdf:resource="#MuscleGain"/>
        <mealSuitableForGoal rdf:resource="#Endurance"/>
    </Meal>
    <Meal rdf:about="#PlantProteinLunch">
        <rdf:type rdf:resource="#LunchMeal"/>
        <rdf:type rdf:resource="#BalancedMeal"/>
        <rdf:type rdf:resource="#VegetarianMeal"/>
