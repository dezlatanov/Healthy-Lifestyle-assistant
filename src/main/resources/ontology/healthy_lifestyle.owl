        <fiberGrams rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.0</fiberGrams>
        <providesNutrient rdf:resource="#Protein"/>
        <compatibleWithRestriction rdf:resource="#HighProteinDiet"/>
    </AnimalProteinFood>
    <PlantBasedFood rdf:about="#BrownRice">
