<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/hla/healthy-lifestyle#"
     xml:base="http://www.semanticweb.org/hla/healthy-lifestyle"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

    <owl:Ontology rdf:about="http://www.semanticweb.org/hla/healthy-lifestyle">
        <rdfs:comment>Разширена OWL онтология за здравословен начин на живот с класове, свойства и логически ограничения</rdfs:comment>
        <rdfs:label xml:lang="bg">Healthy Lifestyle Ontology v7</rdfs:label>
    </owl:Ontology>

    <!-- ========== Core Classes ========== -->
    <owl:Class rdf:about="#Goal"/>
    <owl:Class rdf:about="#WeightManagementGoal">
        <rdfs:subClassOf rdf:resource="#Goal"/>
        <owl:disjointWith rdf:resource="#PerformanceGoal"/>
    </owl:Class>
    <owl:Class rdf:about="#PerformanceGoal">
        <rdfs:subClassOf rdf:resource="#Goal"/>
    </owl:Class>
    <owl:Class rdf:about="#Meal">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#containsFood"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="#Food"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    <owl:Class rdf:about="#Food"/>
    <owl:Class rdf:about="#PlantBasedFood">
        <rdfs:subClassOf rdf:resource="#Food"/>
        <owl:disjointWith rdf:resource="#AnimalProteinFood"/>
        <rdfs:label xml:lang="bg">Растителна храна</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="#AnimalProteinFood">
        <rdfs:subClassOf rdf:resource="#Food"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#providesNutrient"/>
                <owl:hasValue rdf:resource="#Protein"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="bg">Животински протеин</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="#DairyFood">
        <rdfs:subClassOf rdf:resource="#Food"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#providesNutrient"/>
                <owl:allValuesFrom rdf:resource="#Macronutrient"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="bg">Млечни продукти</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="#Nutrient"/>
    <owl:Class rdf:about="#Exercise"/>
    <owl:Class rdf:about="#WorkoutPlan">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#recommendedExercise"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="#Exercise"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    <owl:Class rdf:about="#Habit"/>
    <owl:Class rdf:about="#ActivityLevel"/>
    <owl:Class rdf:about="#MealType"/>
    <owl:Class rdf:about="#DietaryRestriction"/>

    <owl:Class rdf:about="#CardioExercise">
        <rdfs:subClassOf rdf:resource="#Exercise"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#durationMinutes"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="#StrengthExercise"/>
        <rdfs:comment>Cardio упражнение с декларирана продължителност</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#StrengthExercise">
        <rdfs:subClassOf rdf:resource="#Exercise"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#intensity"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="#FlexibilityExercise"/>
    </owl:Class>

    <owl:Class rdf:about="#FlexibilityExercise">
        <rdfs:subClassOf rdf:resource="#Exercise"/>
        <owl:disjointWith rdf:resource="#CardioExercise"/>
    </owl:Class>

    <owl:Class rdf:about="#HighIntensityExercise">
        <rdfs:subClassOf rdf:resource="#Exercise"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#hasIntensityLevel"/>
                <owl:hasValue rdf:resource="#HighIntensity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="#LowIntensityExercise"/>
        <rdfs:label xml:lang="bg">Упражнение с висока интензивност</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="#LowIntensityExercise">
        <rdfs:subClassOf rdf:resource="#Exercise"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#hasIntensityLevel"/>
                <owl:hasValue rdf:resource="#LowIntensity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="bg">Упражнение с ниска интензивност</rdfs:label>
    </owl:Class>

    <!-- Nutrient hierarchy -->
    <owl:Class rdf:about="#Macronutrient">
        <rdfs:subClassOf rdf:resource="#Nutrient"/>
        <owl:disjointWith rdf:resource="#Micronutrient"/>
    </owl:Class>
    <owl:Class rdf:about="#Micronutrient">
        <rdfs:subClassOf rdf:resource="#Nutrient"/>
    </owl:Class>
    <owl:Class rdf:about="#Vitamin">
        <rdfs:subClassOf rdf:resource="#Micronutrient"/>
        <owl:disjointWith rdf:resource="#Mineral"/>
        <rdfs:label xml:lang="bg">Витамин</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="#Mineral">
        <rdfs:subClassOf rdf:resource="#Micronutrient"/>
        <rdfs:label xml:lang="bg">Минерал</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="#IntensityLevel"/>

    <owl:Class rdf:about="#HighFiberFood">
        <rdfs:subClassOf rdf:resource="#Food"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#fiberGrams"/>
                <owl:someValuesFrom>
                    <rdfs:Datatype>
                        <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
                        <owl:withRestrictions rdf:parseType="Collection">
                            <rdf:Description>
                                <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#double">5.0</xsd:minInclusive>
                            </rdf:Description>
                            <rdf:Description/>
                        </owl:withRestrictions>
                    </rdfs:Datatype>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="#Food"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="#fiberGrams"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#double">5.0</xsd:minInclusive>
                                    </rdf:Description>
                                    <rdf:Description/>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:label xml:lang="bg">Храна с високи фибри</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="#PostWorkoutMeal">
        <rdfs:subClassOf rdf:resource="#Meal"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#containsFood"/>
                <owl:someValuesFrom rdf:resource="#HighProteinFood"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#mealSuitableForGoal"/>
                <owl:hasValue rdf:resource="#MuscleGain"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="bg">Ястие след тренировка</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="#SnackMeal">
        <rdfs:subClassOf rdf:resource="#Meal"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#hasMealType"/>
                <owl:hasValue rdf:resource="#Snack"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#containsFood"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">3</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="#BreakfastMeal"/>
    </owl:Class>

    <owl:Class rdf:about="#VegetarianMeal">
        <rdfs:subClassOf rdf:resource="#Meal"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#containsFood"/>
                <owl:allValuesFrom rdf:resource="#PlantBasedFood"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="bg">Вегетарианско ястие</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="#EnduranceWorkoutPlan">
        <rdfs:subClassOf rdf:resource="#WorkoutPlan"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#planSuitableForGoal"/>
                <owl:hasValue rdf:resource="#Endurance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#recommendedExercise"/>
                <owl:someValuesFrom rdf:resource="#CardioExercise"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="#MindfulnessHabit">
        <rdfs:subClassOf rdf:resource="#Habit"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#supportsGoal"/>
                <owl:someValuesFrom rdf:resource="#Goal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="#SleepHabit">
        <rdfs:subClassOf rdf:resource="#Habit"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#targetSleepHours"/>
                <owl:someValuesFrom>
                    <rdfs:Datatype>
                        <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
                        <owl:withRestrictions rdf:parseType="Collection">
                            <rdf:Description>
                                <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#double">7.0</xsd:minInclusive>
                            </rdf:Description>
                            <rdf:Description/>
                        </owl:withRestrictions>
                    </rdfs:Datatype>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- Food specializations — DEFINED CLASSES (equivalentClass for reasoner) -->
    <owl:Class rdf:about="#HighProteinFood">
        <rdfs:subClassOf rdf:resource="#Food"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#proteinGrams"/>
                <owl:someValuesFrom>
                    <rdfs:Datatype>
                        <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
                        <owl:withRestrictions rdf:parseType="Collection">
                            <rdf:Description>
                                <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#double">15.0</xsd:minInclusive>
                            </rdf:Description>
                            <rdf:Description/>
                        </owl:withRestrictions>
                    </rdfs:Datatype>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="#Food"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="#proteinGrams"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#double">15.0</xsd:minInclusive>
                                    </rdf:Description>
                                    <rdf:Description/>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:label xml:lang="bg">Високопroteинова храна</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="#LowCalorieFood">
        <rdfs:subClassOf rdf:resource="#Food"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#calories"/>
                <owl:someValuesFrom>
                    <rdfs:Datatype>
                        <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                        <owl:withRestrictions rdf:parseType="Collection">
                            <rdf:Description>
                                <xsd:maxInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">120</xsd:maxInclusive>
                            </rdf:Description>
                            <rdf:Description/>
                        </owl:withRestrictions>
                    </rdfs:Datatype>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="#Food"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="#calories"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:maxInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">120</xsd:maxInclusive>
                                    </rdf:Description>
                                    <rdf:Description/>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:label xml:lang="bg">Нискокалорична храна</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="#LeanProteinFood">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="#HighProteinFood"/>
                    <rdf:Description rdf:about="#LowCalorieFood"/>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:label xml:lang="bg">Lean protein (висок протеин, ниско калории)</rdfs:label>
    </owl:Class>

    <!-- Meal specializations -->
    <owl:Class rdf:about="#BalancedMeal">
        <rdfs:subClassOf rdf:resource="#Meal"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#containsFood"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="#Food"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="bg">Балансирано ястие</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="#BreakfastMeal">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="#Meal"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="#hasMealType"/>
                        <owl:hasValue rdf:resource="#Breakfast"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <owl:disjointWith rdf:resource="#LunchMeal"/>
    </owl:Class>

    <owl:Class rdf:about="#LunchMeal">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="#Meal"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="#hasMealType"/>
                        <owl:hasValue rdf:resource="#Lunch"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <owl:disjointWith rdf:resource="#DinnerMeal"/>
    </owl:Class>

    <owl:Class rdf:about="#DinnerMeal">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="#Meal"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="#hasMealType"/>
                        <owl:hasValue rdf:resource="#Dinner"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>

    <!-- Habit specializations -->
    <owl:Class rdf:about="#HydrationHabit">
        <rdfs:subClassOf rdf:resource="#Habit"/>
        <owl:disjointWith rdf:resource="#SleepHabit"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#frequencyPerWeek"/>
                <owl:someValuesFrom>
                    <rdfs:Datatype>
                        <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                        <owl:withRestrictions rdf:parseType="Collection">
                            <rdf:Description>
                                <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">7</xsd:minInclusive>
                            </rdf:Description>
                            <rdf:Description/>
                        </owl:withRestrictions>
                    </rdfs:Datatype>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="#ActivityHabit">
        <rdfs:subClassOf rdf:resource="#Habit"/>
        <owl:disjointWith rdf:resource="#MindfulnessHabit"/>
    </owl:Class>

    <!-- Person with logical constraints -->
    <owl:Class rdf:about="#Person">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#hasGoal"/>
                <owl:exactCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:exactCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#hasActivityLevel"/>
                <owl:exactCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:exactCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#username"/>
                <owl:exactCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:exactCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#tracksHabit"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- Meal must contain at least one food — merged into #Meal above -->

    <!-- WorkoutPlan must recommend at least one exercise — merged into #WorkoutPlan above -->

    <!-- ========== Object Properties ========== -->
    <owl:ObjectProperty rdf:about="#hasGoal">
        <rdfs:domain rdf:resource="#Person"/>
        <rdfs:range rdf:resource="#Goal"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#hasActivityLevel">
        <rdfs:domain rdf:resource="#Person"/>
        <rdfs:range rdf:resource="#ActivityLevel"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#consumes">
        <rdfs:domain rdf:resource="#Person"/>
        <rdfs:range rdf:resource="#Meal"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#containsFood">
        <rdfs:domain rdf:resource="#Meal"/>
        <rdfs:range rdf:resource="#Food"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#providesNutrient">
        <rdfs:domain rdf:resource="#Food"/>
        <rdfs:range rdf:resource="#Nutrient"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#recommendedExercise">
        <rdfs:domain rdf:resource="#WorkoutPlan"/>
        <rdfs:range rdf:resource="#Exercise"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#mealSuitableForGoal">
        <rdfs:domain rdf:resource="#Meal"/>
        <rdfs:range rdf:resource="#Goal"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#exerciseSuitableForGoal">
        <rdfs:domain rdf:resource="#Exercise"/>
        <rdfs:range rdf:resource="#Goal"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#planSuitableForGoal">
        <rdfs:domain rdf:resource="#WorkoutPlan"/>
        <rdfs:range rdf:resource="#Goal"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#tracksHabit">
        <rdfs:domain rdf:resource="#Person"/>
        <rdfs:range rdf:resource="#Habit"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#hasMealType">
        <rdfs:domain rdf:resource="#Meal"/>
        <rdfs:range rdf:resource="#MealType"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#compatibleWithRestriction">
        <rdfs:domain rdf:resource="#Food"/>
        <rdfs:range rdf:resource="#DietaryRestriction"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#supportsGoal">
        <rdfs:domain rdf:resource="#Habit"/>
        <rdfs:range rdf:resource="#Goal"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#hasIntensityLevel">
        <rdfs:domain rdf:resource="#Exercise"/>
        <rdfs:range rdf:resource="#IntensityLevel"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#recommendedForActivityLevel">
        <rdfs:domain rdf:resource="#WorkoutPlan"/>
        <rdfs:range rdf:resource="#ActivityLevel"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    </owl:ObjectProperty>

    <!-- Inverse properties -->
    <owl:ObjectProperty rdf:about="#isContainedIn">
        <rdfs:domain rdf:resource="#Food"/>
        <rdfs:range rdf:resource="#Meal"/>
        <owl:inverseOf rdf:resource="#containsFood"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#nutrientSourceFood">
        <rdfs:domain rdf:resource="#Nutrient"/>
        <rdfs:range rdf:resource="#Food"/>
        <owl:inverseOf rdf:resource="#providesNutrient"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#goalHeldBy">
        <rdfs:domain rdf:resource="#Goal"/>
        <rdfs:range rdf:resource="#Person"/>
        <owl:inverseOf rdf:resource="#hasGoal"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#exerciseInPlan">
        <rdfs:domain rdf:resource="#Exercise"/>
        <rdfs:range rdf:resource="#WorkoutPlan"/>
        <owl:inverseOf rdf:resource="#recommendedExercise"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#supportedByHabit">
        <rdfs:domain rdf:resource="#Goal"/>
        <rdfs:range rdf:resource="#Habit"/>
        <owl:inverseOf rdf:resource="#supportsGoal"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#consumedBy">
        <rdfs:domain rdf:resource="#Meal"/>
        <rdfs:range rdf:resource="#Person"/>
        <owl:inverseOf rdf:resource="#consumes"/>
    </owl:ObjectProperty>

    <!-- Symmetric / Asymmetric / Transitive properties -->
    <owl:ObjectProperty rdf:about="#complementsExercise">
        <rdfs:domain rdf:resource="#Exercise"/>
        <rdfs:range rdf:resource="#Exercise"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:comment>Упражнения, които се допълват в един тренировъчен режим</rdfs:comment>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#moreIntenseThan">
        <rdfs:domain rdf:resource="#IntensityLevel"/>
        <rdfs:range rdf:resource="#IntensityLevel"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#includesExercise">
        <rdfs:subPropertyOf rdf:resource="#recommendedExercise"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="#WorkoutPlan"/>
        <rdfs:range rdf:resource="#Exercise"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#sameGoalCategory">
        <rdfs:domain rdf:resource="#Goal"/>
        <rdfs:range rdf:resource="#Goal"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ReflexiveProperty"/>
    </owl:ObjectProperty>

    <!-- ========== Datatype Properties ========== -->
    <owl:DatatypeProperty rdf:about="#username">
        <rdfs:domain rdf:resource="#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#calories">
        <rdfs:domain rdf:resource="#Food"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#proteinGrams">
        <rdfs:domain rdf:resource="#Food"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#fiberGrams">
        <rdfs:domain rdf:resource="#Food"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#durationMinutes">
        <rdfs:domain rdf:resource="#Exercise"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#intensity">
        <rdfs:domain rdf:resource="#Exercise"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#goalName">
        <rdfs:domain rdf:resource="#Goal"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#habitName">
        <rdfs:domain rdf:resource="#Habit"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#frequencyPerWeek">
        <rdfs:domain rdf:resource="#Habit"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#targetDailyMl">
        <rdfs:domain rdf:resource="#HydrationHabit"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#targetSleepHours">
        <rdfs:domain rdf:resource="#SleepHabit"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#targetSteps">
        <rdfs:domain rdf:resource="#ActivityHabit"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#recommendedDailyCalories">
        <rdfs:domain rdf:resource="#Goal"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#servingSizeGrams">
        <rdfs:domain rdf:resource="#Food"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <!-- ========== Individuals: Goals ========== -->
    <WeightManagementGoal rdf:about="#WeightLoss">
        <goalName>weight_loss</goalName>
        <recommendedDailyCalories rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1800</recommendedDailyCalories>
        <rdfs:label xml:lang="bg">Отслабване</rdfs:label>
        <sameGoalCategory rdf:resource="#Maintenance"/>
    </WeightManagementGoal>
    <PerformanceGoal rdf:about="#MuscleGain">
        <goalName>muscle_gain</goalName>
        <recommendedDailyCalories rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2600</recommendedDailyCalories>
        <rdfs:label xml:lang="bg">Мускулна маса</rdfs:label>
        <sameGoalCategory rdf:resource="#Endurance"/>
    </PerformanceGoal>
    <WeightManagementGoal rdf:about="#Maintenance">
        <goalName>maintenance</goalName>
        <recommendedDailyCalories rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2200</recommendedDailyCalories>
        <rdfs:label xml:lang="bg">Поддържане</rdfs:label>
        <sameGoalCategory rdf:resource="#WeightLoss"/>
    </WeightManagementGoal>
    <PerformanceGoal rdf:about="#Endurance">
        <goalName>endurance</goalName>
        <recommendedDailyCalories rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2800</recommendedDailyCalories>
        <rdfs:label xml:lang="bg">Издръжливост</rdfs:label>
        <sameGoalCategory rdf:resource="#MuscleGain"/>
    </PerformanceGoal>

    <!-- Meal types -->
    <MealType rdf:about="#Breakfast">
        <rdfs:label xml:lang="bg">Закуска</rdfs:label>
    </MealType>
    <MealType rdf:about="#Lunch">
        <rdfs:label xml:lang="bg">Обяд</rdfs:label>
    </MealType>
    <MealType rdf:about="#Dinner">
        <rdfs:label xml:lang="bg">Вечеря</rdfs:label>
    </MealType>
    <MealType rdf:about="#Snack">
        <rdfs:label xml:lang="bg">Междинна закуска</rdfs:label>
    </MealType>

    <!-- Intensity levels (transitive ordering via moreIntenseThan) -->
    <IntensityLevel rdf:about="#LowIntensity">
        <rdfs:label xml:lang="bg">Ниска</rdfs:label>
    </IntensityLevel>
    <IntensityLevel rdf:about="#ModerateIntensity">
        <rdfs:label xml:lang="bg">Умерена</rdfs:label>
        <moreIntenseThan rdf:resource="#LowIntensity"/>
    </IntensityLevel>
    <IntensityLevel rdf:about="#HighIntensity">
        <rdfs:label xml:lang="bg">Висока</rdfs:label>
        <moreIntenseThan rdf:resource="#ModerateIntensity"/>
    </IntensityLevel>

    <!-- Dietary restrictions -->
    <DietaryRestriction rdf:about="#HighProteinDiet">
        <rdfs:label xml:lang="bg">Високопroteинов режим</rdfs:label>
    </DietaryRestriction>
    <DietaryRestriction rdf:about="#LowCalorieDiet">
        <rdfs:label xml:lang="bg">Нискокалоричен режим</rdfs:label>
    </DietaryRestriction>
    <DietaryRestriction rdf:about="#VegetarianDiet">
        <rdfs:label xml:lang="bg">Вегетариански режим</rdfs:label>
    </DietaryRestriction>
    <DietaryRestriction rdf:about="#GlutenFreeDiet">
        <rdfs:label xml:lang="bg">Без глутен</rdfs:label>
    </DietaryRestriction>

    <!-- Activity Levels -->
    <ActivityLevel rdf:about="#Sedentary">
        <rdfs:label xml:lang="bg">Заседнал</rdfs:label>
    </ActivityLevel>
    <ActivityLevel rdf:about="#Moderate">
        <rdfs:label xml:lang="bg">Умерена активност</rdfs:label>
    </ActivityLevel>
    <ActivityLevel rdf:about="#Active">
        <rdfs:label xml:lang="bg">Активен</rdfs:label>
    </ActivityLevel>

    <!-- Foods (typed for taxonomy + reasoner classification) -->
    <AnimalProteinFood rdf:about="#ChickenBreast">
